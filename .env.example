# === Обязательное ===

# Токен бота от @BotFather
BOT_TOKEN=123456789:AAExxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Ключ DeepSeek с https://platform.deepseek.com/  (добавишь позже)
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# === Необязательное (значения по умолчанию подходят) ===

# Модель. deepseek-v4-flash — дёшево и быстро.
# Старое имя deepseek-chat работает до 2026-07-24.
DEEPSEEK_MODEL=deepseek-v4-flash

# Поведение «Шалуна»
REPLY_PROBABILITY=0.15      # шанс спонтанно встрять (0..1)
REPLY_COOLDOWN=60           # сек между спонтанными вмешательствами в одном чате
CONTEXT_WINDOW=12           # сколько последних сообщений отдаём модели
TEMPERATURE=1.2             # выше — живее/непредсказуемее
TYPING_DELAY=1.5            # пауза «печатает…» перед ответом, сек

# Ограничить работу конкретными чатами (id через запятую). Пусто = во всех.
ALLOWED_CHAT_IDS=
